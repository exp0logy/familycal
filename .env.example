# ─────────────────────────────────────────────────────────────────────────────
# Family Organiser — environment configuration
# Copy to `.env` and fill in. NEVER commit your real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ────────────────────────────────────────────────────────────────────
APP_NAME="Family Organiser"
# Bind host/port for the backend (uvicorn). 0.0.0.0 = reachable on the LAN.
HOST=0.0.0.0
PORT=8000
# Comma-separated origins allowed to call the API (your LAN device IPs / hostnames).
# Use * only on a trusted LAN.
CORS_ORIGINS=*
# Directory for SQLite db + cached photos (mounted as a Docker volume).
DATA_DIR=./data
# 32-byte url-safe base64 key used to encrypt stored secrets at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

# Public base URL the browser uses to reach the app. This MUST be the DASHBOARD
# (frontend) origin, NOT the backend :8000 port — the OAuth callback redirects to the
# SPA served by the frontend. Google OAuth rejects private IPs and bare http for
# non-localhost, so use an HTTPS domain in production:
#   Production: https://home.example.dev   (a real domain over HTTPS, served on :443)
#   Local dev:  http://localhost:5173       (the Vite dev server)
# Register "<PUBLIC_BASE_URL>/api/oauth/<provider>/callback" as the redirect URI.
# NOTE: Google never connects to this URL — only the user's browser does — so the
# domain only needs to resolve to this box on your LAN (split-horizon DNS); it does
# NOT need to be reachable from the public internet (don't port-forward).
PUBLIC_BASE_URL=https://home.example.dev

# ── TLS (frontend HTTPS) ──────────────────────────────────────────────────────
# The frontend serves HTTPS on :443. By default it auto-generates a self-signed cert
# for TLS_HOSTNAME (browser warning until trusted). For a trusted cert, obtain one
# (e.g. Let's Encrypt via DNS-01 — no public exposure needed) and place it at
# ./certs/cert.pem and ./certs/key.pem; it will be used automatically.
TLS_HOSTNAME=home.example.dev
TLS_IP=192.168.1.50

# ── Background sync ───────────────────────────────────────────────────────────
CALENDAR_SYNC_INTERVAL_MINUTES=15

# ── Google (Calendar API + Photos Library API) ───────────────────────────────
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console.
# Authorized redirect URI: ${PUBLIC_BASE_URL}/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft 365 / Outlook (Graph API) ──────────────────────────────────────
# Register an app in Entra ID (Azure AD). Redirect URI (Web):
# ${PUBLIC_BASE_URL}/api/oauth/microsoft/callback
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common

# ── Weather (Open-Meteo — no key required) ───────────────────────────────────
WEATHER_LATITUDE=-37.8136
WEATHER_LONGITUDE=144.9631
WEATHER_LOCATION_LABEL="Melbourne"
WEATHER_UNITS=metric

# ── Frontend (build-time, public — NEVER put secrets here) ───────────────────
VITE_API_BASE=/api
VITE_WS_BASE=/ws
